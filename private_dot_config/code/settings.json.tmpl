{
  "editor.cursorBlinking": "smooth",
  "workbench.editor.showTabs": "multiple",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "workbench.colorCustomizations": {

    "editorRuler.foreground": "#fffff1"
  },
  "window.title": "${activeEditorShort}${separator}${rootName}${separator}${profileName}",
  "window.titleBarStyle": "custom",
  "editor.codeLens": false,
  "editor.tabSize": 2,
  "editor.minimap.enabled": false,
  "editor.formatOnPaste": false,
  "editor.formatOnSave": false,
  "editor.fontFamily": "FiraCode Nerd Font, 'Droid Sans Mono', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.rulers": [80],
  "editor.wordWrap": "on",
  "editor.wrappingIndent": "indent",
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.list.horizontalScrolling": true,
  "files.trimTrailingWhitespace": true,
  "terminal.external.osxExec": "Ghostty.app",
  "terminal.integrated.fontFamily": "Dank Mono, Hack, Menlo, Monaco, monospace",
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.lineHeight": 1.4,
  "git.autofetch": true,
  "git.alwaysSignOff": true,
  "git.fetchOnPull": true,
  "git.confirmSync": false,
  "git.rebaseWhenSync": true,
  "git.showPushSuccessNotification": true,
  "workbench.startupEditor": "newUntitledFile",
  "yaml.customTags": ["!vault"],
  "editor.suggestSelection": "first",
  "[python]": {
    "editor.formatOnType": true
  },
  "json.format.enable": false,
  "json.format.keepLines": true,
  "debug.javascript.terminalOptions": {},
  "debug.javascript.pickAndAttachOptions": {},
  "go.toolsManagement.autoUpdate": true,
  "git.enableCommitSigning": true,
  "diffEditor.experimental.showMoves": true,
  "workbench.editor.enablePreview": false,
  "workbench.colorTheme": "One Dark Pro Flat",
  "git.replaceTagsWhenPull": true,
  "git.ignoreRebaseWarning": true,
  "git.enableSmartCommit": true,
  "gopls": {},
  "workbench.iconTheme": "symbols",
  "cSpell.userWords": [
    "atko",
    "awshelper",
    "Awsvpc",
    "boolplanmodifier",
    "btrfs",
    "bubbletea",
    "bubblezone",
    "CERTDIR",
    "charmbracelet",
    "cloudinit",
    "cloudwatchlogs",
    "codereview",
    "controlv",
    "dockerlib",
    "durationpb",
    "endfor",
    "fakellan",
    "Fargate",
    "formatlist",
    "goarch",
    "Healthcheck",
    "iface",
    "jmespath",
    "keymap",
    "lapu",
    "lipgloss",
    "lrstanley",
    "mergerequest",
    "mergerequests",
    "Multiregion",
    "nvme",
    "ONCALL",
    "Pazeculan",
    "planmodifier",
    "pokedex",
    "Pokédex",
    "Populator",
    "providerplugin",
    "providerutil",
    "putona",
    "rabbitmq",
    "releasever",
    "reuseaddr",
    "Sdump",
    "sess",
    "showduplicates",
    "socat",
    "splitted",
    "stringplanmodifier",
    "Sumologic",
    "termenv",
    "textinput",
    "tfsdk",
    "tidwall",
    "tonumber",
    "toset",
    "TRIGGERER",
    "usermod",
    "vlctechfest",
    "wadus"
  ],
  "github.copilot.advanced": {
    "chat.agent.enabled": true
  },
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": false,
    "scminput": false
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "security.workspace.trust.untrustedFiles": "open",
  "chat.agent.maxRequests": 50,
  "redhat.telemetry.enabled": true,
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
{{- if eq .profile "mac_work" }}
  },
  "git.blame.editorDecoration.enabled": false,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "workbench.secondarySideBar.defaultVisibility": "visible",
  "vs-kubernetes": {
    "vs-kubernetes.minikube-show-information-expiration": "2026-03-14T08:34:04.505Z"
  },
  "chat.viewSessions.orientation": "stacked",
  "chat.viewSessions.enabled": false,
  "chat.tips.enabled": false,
  "chat.tools.urls.autoApprove": {
    "https://code.visualstudio.com": true,
    "https://github.com/microsoft/vscode/wiki/*": true,
    "https://www.vaultproject.io": {
      "approveRequest": true,
      "approveResponse": false
    }
  }
{{- else }}
  }
{{- end }}
}
